import IO from "IO"

import { className } from "@/Attribute"
import { div, p, render } from "@/Spinneret"
import { bem } from "@/Style"



main = () => {
  s = bem("App")
  name = s.e("core")
  IO.put(name)
  #- console.log("name", name) -#
  render("app", <div className={name}><p>Hey this is magical!</p></div>)
}
